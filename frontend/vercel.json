{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_API_URL": "Your Cloud Run backend URL goes here (e.g., https://api-mindfuel-xxx.a.run.app)"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-cloud-run-url.a.run.app/:path*"
    }
  ]
}
